---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;

const imageModules = import.meta.glob<{ default: ImageMetadata }>('../../assets/notes/*', {
  eager: true,
});

// 本文中の /assets/xxx 参照を astro:assets 最適化済みURLへ書き換える
const replacements = new Map<string, string>();
for (const name of article.data.images) {
  const mod = imageModules[`../../assets/notes/${name}`];
  if (!mod) continue;
  const optimized = await getImage({ src: mod.default });
  replacements.set(`/assets/${name}`, optimized.src);
}

let html = article.data.html.replace(
  /(<img\b[^>]*?src=")(\/assets\/[^"]+)(")/g,
  (match, pre, src, post) => {
    const replaced = replacements.get(src);
    return replaced ? `${pre}${replaced}${post} loading="lazy"` : match;
  }
);

// 査読マークの位置合わせ用に、本文の<p>タグへ通し番号を付与する
let paragraphIndex = 0;
html = html.replace(/<p\b/g, () => `<p data-p-index="${paragraphIndex++}"`);

const reviewMarks = article.data.reviewMarks;
---

<BaseLayout title={article.data.title}>
  <div class="editorial-grid">
    <div class="main">
      <a class="back" href="../archive.html">← 一覧に戻る</a> ｜ <a class="back" href="../index.html">プロフィール</a>
      <h1 class="title">{article.data.title}</h1>
      <div class="date">
        {article.data.date}　原文: <a href={article.data.noteUrl} target="_blank">note</a>
      </div>
      <div class="content" set:html={html} />
    </div>

    <div class="rail" id="rail">
      {reviewMarks.map((mark) => (
        <div class="mark" data-after={mark.afterParagraph}>{mark.text}</div>
      ))}
    </div>
  </div>
</BaseLayout>

<style is:global>
  h1.title { font-size: 22px; line-height: 1.6; margin: 20px 0 8px; }
  .date { font-family: 'Outfit', sans-serif; font-size: 12px; color: var(--faint); margin-bottom: 28px; }
  .date a { color: var(--teal); }
  .content img { max-width: 100%; height: auto; border-radius: 6px; display: block; margin: 16px auto; }
  .content h2 {
    font-size: 17px; border-left: 4px solid var(--brass);
    padding-left: 10px; margin-top: 36px;
  }
  .content p { margin: 16px 0; }
  .content figure { margin: 20px 0; }
  .content figcaption { font-family: 'Outfit', sans-serif; font-size: 12px; color: var(--faint); text-align: center; margin-top: 4px; }
  .content a { color: var(--teal); }
  .content a:hover { color: var(--brass); }
  .content blockquote {
    margin: 20px 0; padding: 2px 16px; border-left: 3px solid var(--border);
    color: var(--muted);
  }
</style>

<script>
  const rail = document.getElementById('rail');
  const marks = document.querySelectorAll<HTMLElement>('.mark[data-after]');

  function positionMarks() {
    if (!rail) return;
    const railRect = rail.getBoundingClientRect();
    marks.forEach((mark) => {
      const targetIndex = mark.dataset.after;
      const paragraph = document.querySelector<HTMLElement>(`.content p[data-p-index="${targetIndex}"]`);
      if (!paragraph) return;
      const pRect = paragraph.getBoundingClientRect();
      mark.style.position = 'absolute';
      mark.style.top = `${pRect.top - railRect.top}px`;
    });
  }

  positionMarks();
  window.addEventListener('resize', positionMarks);
  window.addEventListener('load', positionMarks);

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.3 }
  );
  marks.forEach((mark) => observer.observe(mark));
</script>
