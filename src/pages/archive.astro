---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = (await getCollection('articles')).sort((a, b) =>
  b.data.datetime.localeCompare(a.data.datetime)
);
---

<BaseLayout title="金田まり 記事アーカイブ">
  <div class="wrap wrap--mid">
    <div class="nav"><a href="index.html">← プロフィール</a><a href="gallery.html">ギャラリー →</a></div>
    <div class="eyebrow">KANEDA MARI — ARCHIVE</div>
    <h1>無料記事アーカイブ({articles.length}件)</h1>
    <div class="list">
      {articles.map((article) => (
        <a class="link-card" href={`articles/${article.id}.html`}>
          <div class="t">{article.data.title}</div>
          <div class="d">{article.data.date}</div>
        </a>
      ))}
    </div>
    <div class="note">原文はnoteで公開されています。</div>
  </div>
</BaseLayout>

<style>
  h1 { font-size: 22px; margin: 6px 0 24px; }
  .list { display: flex; flex-direction: column; gap: 12px; }
  .link-card .t { font-size: 15px; line-height: 1.6; margin-bottom: 6px; }
  .link-card .d { font-size: 11px; color: var(--faint); font-family: var(--font-ui); }
  .note { margin-top: 28px; }
</style>
