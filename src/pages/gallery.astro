---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryArticles = (await getCollection('articles'))
  .filter((a) => a.data.gallery)
  .sort((a, b) => a.data.datetime.localeCompare(b.data.datetime));

const imageModules = import.meta.glob<{ default: ImageMetadata }>('../assets/notes/*', {
  eager: true,
});

const sections = [];
let totalImages = 0;
for (const article of galleryArticles) {
  const images = [];
  for (const name of article.data.images) {
    const mod = imageModules[`../assets/notes/${name}`];
    if (!mod) continue;
    const thumb = await getImage({ src: mod.default, width: 320 });
    const full = await getImage({ src: mod.default });
    images.push({ thumb: thumb.src, full: full.src });
  }
  totalImages += images.length;
  sections.push({ title: article.data.title, date: article.data.date, images });
}
---

<BaseLayout title="イラストギャラリー | 金田まり">
  <div class="wrap wrap--wide">
    <a class="back" href="index.html">← プロフィール</a> ｜ <a class="back" href="archive.html">記事アーカイブ →</a>
    <div class="eyebrow eyebrow--gallery">KANEDA MARI — GALLERY</div>
    <h1>イラストギャラリー</h1>
    <div class="sub">AI活用イラスト全{sections.length}投稿・{totalImages}枚(note公開記事より)</div>

    {sections.map((section) => (
      <div class="section">
        <div class="section-head">{section.title}</div>
        <div class="section-date">{section.date}</div>
        <div class="grid">
          {section.images.map((img) => (
            <img src={img.thumb} data-full={img.full} loading="lazy" alt="" />
          ))}
        </div>
      </div>
    ))}
  </div>

  <div id="lightbox">
    <button class="close" aria-label="閉じる">×</button>
    <img id="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<style>
  body { line-height: 1.8; }
  .eyebrow--gallery { margin-top: 20px; }
  h1 { font-size: 22px; margin: 6px 0 6px; }
  .sub { font-size: 13px; color: var(--color-muted); margin-bottom: 36px; }
  .section { margin-bottom: 40px; }
  .section-head { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
  .section-date { font-size: 11px; color: var(--color-faint); margin-bottom: 12px; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 6px; }
  .grid img {
    width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 6px;
    cursor: pointer; display: block; background: var(--color-border);
  }
  .grid img:hover { opacity: .85; }
  #lightbox {
    display: none; position: fixed; inset: 0; background: rgba(15, 20, 22, .9);
    z-index: 100; align-items: center; justify-content: center; padding: 20px;
  }
  #lightbox.open { display: flex; }
  #lightbox img { max-width: 100%; max-height: 90vh; border-radius: 8px; }
  #lightbox .close {
    position: absolute; top: 20px; right: 24px; color: #fff;
    font-size: 28px; cursor: pointer; background: none; border: none;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

  document.querySelectorAll<HTMLImageElement>('.grid img').forEach((img) => {
    img.addEventListener('click', () => {
      lightboxImg.src = img.dataset.full || img.src;
      lightbox.classList.add('open');
    });
  });
  lightbox.addEventListener('click', () => {
    lightbox.classList.remove('open');
    lightboxImg.src = '';
  });
</script>
